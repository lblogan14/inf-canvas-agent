# Copy to .env and fill in. Never commit .env.

# --- LLM provider --------------------------------------------------------
# Default "gemini" (uses the google-genai SDK directly). Any other provider —
# openai, anthropic, google_genai, groq, mistralai, ... — is served through
# LangChain; install the extra first:  cd backend && uv sync --extra providers
LLM_PROVIDER=gemini

# Model ids per agent role. MODEL_* are provider-agnostic; the legacy
# GEMINI_MODEL_* names still work for the Gemini provider.
MODEL_PRO=gemini-2.5-pro
MODEL_FLASH=gemini-2.5-flash
# Vision/extraction: newest model for best spatial grounding.
MODEL_VISION=gemini-3.1-pro-preview

# --- Provider API keys ---------------------------------------------------
# Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-key-here
# Other providers read their own env var when LLM_PROVIDER is set to them:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Backend config (optional) -------------------------------------------
# Where projects/uploads are stored (relative to backend/)
STORAGE_DIR=storage
# CORS origin for the Vite dev server
FRONTEND_ORIGIN=http://localhost:5173
# Extractor accuracy passes (disable for speed):
# EXTRACTOR_VERIFY=true
# EXTRACTOR_LINE_HYBRID=true
