# Copy to .env and fill in. Never commit .env.
# Google Gemini API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-key-here

# --- Backend config (optional overrides; see backend/src/inf_canvas/config.py) ---
# Gemini model ids per role
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_VISION=gemini-2.5-pro

# Where projects/uploads are stored (relative to backend/)
STORAGE_DIR=storage

# CORS origin for the Vite dev server
FRONTEND_ORIGIN=http://localhost:5173
